rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // El id del documento ES la llave (modelo de capacidad, sin cuentas).
    function codigoValido(code) {
      return code is string && code.size() >= 12 && code.size() <= 128;
    }
    // Documento propio de la herramienta, acotado en tamaño.
    function payloadValido(d) {
      return d.app == "matriz-aps"
        && d.data is string
        && d.data.size() < 1000000                         // < 1 MB anti-abuso
        && (!('comuna' in d) || d.comuna is string);
    }

    match /matrices/{code} {
      allow get:    if codigoValido(code);                 // sin el código largo, nada
      allow list:   if false;                              // no enumerable
      allow create: if codigoValido(code) && payloadValido(request.resource.data);
      allow update: if codigoValido(code)
                    && payloadValido(request.resource.data)
                    && request.resource.data.app == resource.data.app; // 'app' inmutable
      allow delete: if false;
    }

    // Denegación por defecto para todo lo demás.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
