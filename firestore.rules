rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sincronización por CÓDIGO (sin cuentas): el id del documento ES la llave.
    // - El código debe ser largo (no adivinable). Se prohíbe listar la colección,
    //   así nadie puede enumerar códigos ajenos.
    // - Solo se aceptan documentos de esta herramienta y de tamaño acotado.
    match /matrices/{code} {
      allow get: if code.size() >= 12;
      allow list: if false;
      allow create, update: if code.size() >= 12
        && request.resource.data.app == "matriz-aps"
        && request.resource.data.data is string
        && request.resource.data.data.size() < 1000000;
      allow delete: if false;
    }

    // Todo lo demás: denegado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
